[
    {
        "idx": 0,
        "type": "narration",
        "text": "Ali, Sara, Omar, and Lina were sitting in the park as the sun slowly set behind the trees. Ali said,",
        "speaker": null,
        "emotion": null,
        "voice_id": "JBFqnCBsd6RMkjVDRZzb"
    },
    {
        "idx": 1,
        "type": "dialogue",
        "text": "This is the best day we have had in a long time.",
        "speaker": "Ali",
        "emotion": "neutral",
        "voice_id": "CwhRBWXzGAHq8TQ4Fs17"
    },
    {
        "idx": 2,
        "type": "narration",
        "text": "Sara smiled and said,",
        "speaker": null,
        "emotion": null,
        "voice_id": "JBFqnCBsd6RMkjVDRZzb"
    },
    {
        "idx": 3,
        "type": "dialogue",
        "text": "I agree, everything feels so calm and peaceful.",
        "speaker": "Sara",
        "emotion": "neutral",
        "voice_id": "cgSgspJ2msm6clMCkdW9"
    },
    {
        "idx": 4,
        "type": "narration",
        "text": "Omar laughed and said,",
        "speaker": null,
        "emotion": null,
        "voice_id": "JBFqnCBsd6RMkjVDRZzb"
    },
    {
        "idx": 5,
        "type": "dialogue",
        "text": "You say that now, but you were the one complaining all morning.",
        "speaker": "Sara",
        "emotion": "neutral",
        "voice_id": "cgSgspJ2msm6clMCkdW9"
    },
    {
        "idx": 6,
        "type": "narration",
        "text": "Sara replied,",
        "speaker": null,
        "emotion": null,
        "voice_id": "JBFqnCBsd6RMkjVDRZzb"
    },
    {
        "idx": 7,
        "type": "dialogue",
        "text": "That was different, I was just tired.",
        "speaker": "Sara",
        "emotion": "fear",
        "voice_id": "cgSgspJ2msm6clMCkdW9"
    },
    {
        "idx": 8,
        "type": "narration",
        "text": "Lina looked around nervously and said,",
        "speaker": null,
        "emotion": null,
        "voice_id": "JBFqnCBsd6RMkjVDRZzb"
    },
    {
        "idx": 9,
        "type": "dialogue",
        "text": "Does anyone else feel like we are being watched?",
        "speaker": "Lina",
        "emotion": "fear",
        "voice_id": "pFZP5JQG7iQjIQuC4Bku"
    },
    {
        "idx": 10,
        "type": "narration",
        "text": "Ali frowned and said,",
        "speaker": null,
        "emotion": null,
        "voice_id": "JBFqnCBsd6RMkjVDRZzb"
    },
    {
        "idx": 11,
        "type": "dialogue",
        "text": "Do not start that again, Lina.",
        "speaker": "Omar",
        "emotion": "neutral",
        "voice_id": "onwK4e9ZLuTAKqWW03F9"
    },
    {
        "idx": 12,
        "type": "narration",
        "text": "Omar said jokingly,",
        "speaker": null,
        "emotion": null,
        "voice_id": "JBFqnCBsd6RMkjVDRZzb"
    },
    {
        "idx": 13,
        "type": "dialogue",
        "text": "Maybe it is just your imagination.",
        "speaker": "Lina",
        "emotion": "neutral",
        "voice_id": "pFZP5JQG7iQjIQuC4Bku"
    },
    {
        "idx": 14,
        "type": "narration",
        "text": "Lina whispered,",
        "speaker": null,
        "emotion": null,
        "voice_id": "JBFqnCBsd6RMkjVDRZzb"
    },
    {
        "idx": 15,
        "type": "dialogue",
        "text": "No, I am serious. I heard something behind us.",
        "speaker": "Sara",
        "emotion": "neutral",
        "voice_id": "cgSgspJ2msm6clMCkdW9"
    },
    {
        "idx": 16,
        "type": "narration",
        "text": "Sara said softly,",
        "speaker": null,
        "emotion": null,
        "voice_id": "JBFqnCBsd6RMkjVDRZzb"
    },
    {
        "idx": 17,
        "type": "dialogue",
        "text": "Okay, now you are making me nervous.",
        "speaker": "Sara",
        "emotion": "fear",
        "voice_id": "cgSgspJ2msm6clMCkdW9"
    }
]